---
import Layout from '@layouts/Layout.astro';
import { supabase, getFormalitiesByStatus } from '@utils/supabase';
import Button from '@components/ui/Button.astro';

const seoTitle = 'Dashboard Admin';
const seoDescription = 'Gérez toutes les demandes reçues via Mon Assistant Formalités.';

// 🔐 Auth
const token = Astro.cookies.get('sb-access-token')?.value;
if (!token) return Astro.redirect('/admin/maf/login');
const {
    data: { user },
} = await supabase.auth.getUser(token);
if (!user) return Astro.redirect('/admin/maf/login');

// Récupération du statut de la formalité via ID
const formalityStatutParam = Number(Astro.url.searchParams.get('statut')) || 1;
const allowedStatuts = [1, 2, 3, 4, 5];
const formalityStatutId = allowedStatuts.includes(formalityStatutParam) ? formalityStatutParam : 1;

type PaymentStatusConfig = {
    label: string;
    color: string;
};

// Labels
const FORMALITY_TYPE: Record<number, PaymentStatusConfig> = {
    1: { label: 'Création', color: 'text-blue-500' },
    2: { label: 'Déménagement', color: 'text-green-500' },
    3: { label: 'Activités', color: 'text-orange-500' },
    4: { label: 'Correction', color: 'text-purple-500' },
    5: { label: 'Cessation', color: 'text-red-500' },
};

const FORMALITY_PAYMENT: Record<number, PaymentStatusConfig> = {
    1: { label: 'Non envoyé', color: 'text-gray-700' },
    2: { label: 'Envoyée', color: 'text-blue-500' },
    3: { label: 'Accepté', color: 'text-green-500' },
    4: { label: 'Echoué', color: 'text-red-500' },
    5: { label: 'Expiré', color: 'text-purple-500' },
    6: { label: 'Annulé', color: 'text-red-500' },
    7: { label: 'Remboursé', color: 'text-orange-500' }
};

// 📡 Récupération
const formalities = await getFormalitiesByStatus(formalityStatutId);
---

<Layout title={seoTitle} description={seoDescription}>
    <div class="w-full min-h-screen pt-28 px-6">
        
        <!-- Header de page -->
        <div class="mb-10">
            <h1 class="text-3xl font-bold">Dashboard Admin</h1>
        </div>

        <!-- Barre actions + filtres -->
        <div class="flex justify-between items-center flex-wrap gap-4 mb-8">           

            <!-- DESKTOP (>= md) -->
            <div class="hidden md:flex gap-2 flex-wrap">
                <Button href="?statut=1" variant={formalityStatutId === 1 ? 'primary' : 'neutral'} size="md">En attente</Button>
                <Button href="?statut=2" variant={formalityStatutId === 2 ? 'primary' : 'neutral'} size="md">En traitement</Button>
                <Button href="?statut=3" variant={formalityStatutId === 3 ? 'primary' : 'neutral'} size="md">Terminé</Button>
                <Button href="?statut=4" variant={formalityStatutId === 4 ? 'primary' : 'neutral'} size="md">Rejetée</Button>
                <Button href="?statut=5" variant={formalityStatutId === 5 ? 'primary' : 'neutral'} size="md">Annulée</Button>
            </div>

            <!-- MOBILE (< md) -->
            <div class="relative md:hidden">
                <Button id="statusDropdownBtn" variant='primary' class='cursor-pointer'>Filtrer par : </Button>

                <div id="statusDropdownMenu" class="hidden absolute mt-2 w-full bg-white border rounded-lg shadow-md z-20">
                    <a href="?statut=1" class="block px-4 py-2 hover:bg-gray-100">En attente</a>
                    <a href="?statut=2" class="block px-4 py-2 hover:bg-gray-100">En traitement</a>
                    <a href="?statut=3" class="block px-4 py-2 hover:bg-gray-100">Terminé</a>
                    <a href="?statut=4" class="block px-4 py-2 hover:bg-gray-100">Rejetée</a>
                    <a href="?statut=5" class="block px-4 py-2 hover:bg-gray-100">Annulée</a>
                </div>
            </div>

            <div>
                <Button id="logout-btn" variant="alert" size="md" class='cursor-pointer'>Déconnexion</Button>
            </div>
        </div>

        <!-- Tableau DESKTOP (>= md) -->
        <div class="hidden md:block w-full overflow-x-auto rounded-xl border border-gray-200 bg-white shadow-sm">
            <table id="formalities-table" class="w-full divide-y divide-gray-200 text-sm">    

                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-4 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider sortable cursor-pointer" data-column="datecreation">Date <span class="sort-indicator">▲▼</span></th>
                        <th class="px-6 py-4 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider sortable cursor-pointer" data-column="name">Nom <span class="sort-indicator">▲▼</span></th>
                        <th class="px-6 py-4 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider sortable cursor-pointer" data-column="typeformaliteid">Formalité <span class="sort-indicator">▲▼</span></th>
                        <th class="px-6 py-4 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider sortable cursor-pointer" data-column="statutpaiementid">Paiement <span class="sort-indicator">▲▼</span> </th>
                        <th class="px-6 py-4 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider">Montant facturé</th>
                        <th class="px-6 py-4 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider">Montant remboursé</th>
                        <th class="px-6 py-4 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider sortable cursor-pointer" data-column="statutpaiementid">N° formalité <span class="sort-indicator">▲▼</span> </th>
                        <th class="px-6 py-4 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider">PDF</th>
                        <th class="px-6 py-4 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider">Actions</th>
                    </tr>
                </thead>

                <tbody class="divide-y divide-gray-100">
                    {formalities.length === 0 ? (
                        <tr>
                            <td colspan="9" class="px-6 py-10 text-center text-gray-500">Aucune demande dans cette catégorie.</td>
                        </tr>
                    ) : (
                        formalities.map(d => (
                            <tr data-id={d.demandeid} data-name={d.name} data-firstname={d.firstname} data-email={d.email} data-payment-status={d.statutpaiementid} data-formality-status={d.statutformaliteid} data-ref_inpi={d.ref_inpi} class="hover:bg-gray-50 transition">
                                
                                <td class="px-6 py-2 text-center whitespace-nowrap text-gray-500" data-sort={new Date(d.datecreation).getTime()}>{new Date(d.datecreation).toLocaleDateString('fr-FR')}</td>
                                <td class="px-6 py-4 text-center whitespace-nowrap font-medium text-gray-900" data-sort={d.name}>{d.name} {d.firstname}</td>
                                <td class={`px-6 py-2 text-center whitespace-nowrap font-medium ${FORMALITY_TYPE[d.typeformaliteid]?.color ?? 'text-gray-400'}`} data-sort={d.typeformaliteid}>{FORMALITY_TYPE[d.typeformaliteid]?.label ?? "Inconnu"}</td>
                                <td class={`px-6 py-2 text-center whitespace-nowrap font-medium ${FORMALITY_PAYMENT[d.statutpaiementid]?.color ?? 'text-gray-400'}`} data-sort={d.statutpaiementid}>{FORMALITY_PAYMENT[d.statutpaiementid]?.label ?? "Inconnu"}</td>
                                <td class={`px-6 py-2 text-center whitespace-nowrap font-medium ${FORMALITY_PAYMENT[d.statutpaiementid]?.color ?? 'text-gray-400'}`}>{(d.amount_paid/100).toFixed(2)} €</td>
                                <td class="px-6 py-4 text-center whitespace-nowrap font-medium text-orange-500">{(d.amount_refunded/100).toFixed(2)} €</td>
                                <td class="px-6 py-2 text-center whitespace-nowrap font-medium text-gray-900" data-sort={d.ref_inpi}>{d.ref_inpi}</td>
                                <td class="px-6 py-2 text-center whitespace-nowrap">
                                    <button class="text-blue-600 text-center hover:underline cursor-pointer" data-pdf={d.pdf}>pdf-{d.id}</button>
                                </td>
                                <td class="text-center px-6 py-2 whitespace-nowrap relative">
                                    <Button variant="primary" size="sm" class="action-btn cursor-pointer">...</Button>
                                </td>
                            </tr>
                        ))
                    )}
                </tbody>

            </table>
        </div>

        <!-- TABLEAU MOBILE (< md) -->
        <div class="md:hidden space-y-4 mb-12">
            {formalities.length === 0 ? (
                <div class="p-6 bg-white rounded-xl border text-center text-gray-500">
                    Aucune demande dans cette catégorie.
                </div>
            ) : (
                formalities.map(d => (
                    <div class="bg-white rounded-xl border shadow-sm p-4 space-y-3">
                        
                        <div class="flex justify-between items-start">
                            <div>
                                <p class="text-small text-gray-500">{new Date(d.datecreation).toLocaleDateString('fr-FR')}</p>
                                <p class="font-semibold text-gray-800">{d.name} {d.firstname}</p>
                            </div>
                            <button class="text-gray-600 text-sm cursor-pointer" data-pdf={d.pdf}>⬇️ PDF</button>
                        </div>

                        <div class="flex justify-between text-sm">
                            <div>
                                <span class="text-gray-500">Formalité : </span>
                                <span class={`font-medium ${FORMALITY_TYPE[d.typeformaliteid]?.color ?? 'text-gray-400'}`}>{FORMALITY_TYPE[d.typeformaliteid]?.label ?? "Inconnu"}</span>
                            </div>
                            <div>
                                <span class="text-gray-500">réf. INPI : </span>
                                <span class='font-medium text-gray-800'>{d.ref_inpi}</span>
                            </div>
                        </div>

                        <div class="flex justify-between text-sm">
                            <span class="text-gray-500">Paiement</span>
                            <span class={`font-medium ${FORMALITY_PAYMENT[d.statutpaiementid]?.color ?? 'text-gray-400'}`}>{FORMALITY_PAYMENT[d.statutpaiementid]?.label ?? "Inconnu"}</span>
                        </div>
                        
                    </div>
                ))
            )}
        </div>
    </div>
</Layout>

<script type="module">
    
    /*** MENU FLOTANT ***/
    const body = document.body;
    let currentMenu = null;
    let currentRow = null;

    const PAYMENT_ACTIONS = {
        1: ['envoyer_facture'],                 // non_genere
        2: ['relancer_facture', 'annuler_facture'],     // envoyee
        3: ['rembourser_facture'],              // accepte
        4: ['relancer_facture', 'annuler_facture'],     // echouee
        5: ['relancer_facture', 'annuler_facture'],     // expiree
        6: ['envoyer_facture'],                 // annulee
        7: []                           // rembourse
    };

    const ACTION_LABELS = {
        envoyer_facture: 'Envoyer la facture',
        relancer_facture: 'Relancer la facture',
        annuler_facture: 'Annuler la facture',
        rembourser_facture: 'Rembourser la facture',

        demarrer_formalite: 'Démarrer la formalité',
        terminer_formalite: 'Formalité Terminée',
        rejeter_formalite: 'Formalité rejetée',
        annuler_formalite: 'Annuler la formalité',

        reference_inpi: '🔢 Ajouter réf. INPI',
        envoyer_mail: '✉️ Envoyer un mail'
    };

    const ACTION_STYLES = {
        envoyer_facture: 'text-blue-600',
        relancer_facture: 'text-blue-600',
        annuler_facture: 'text-red-600',
        rembourser_facture: 'text-red-600',

        demarrer_formalite: 'text-green-600',
        terminer_formalite: 'text-green-600',
        rejeter_formalite: 'text-red-600',
        annuler_formalite: 'text-red-600',

        reference_inpi: 'text-blue-600',
        envoyer_mail: 'text-blue-600',
    };

    // Création du menu flotant
    function createActionMenu() {
        const menu = document.createElement('div');
        menu.className = 'action-menu hidden absolute bg-white border rounded-lg shadow-md z-50';
        menu.style.minWidth = '170px';

        body.appendChild(menu);
        return menu;
    }

    currentMenu = createActionMenu();

    // Click du bouton "..."
    document.querySelectorAll('.action-btn').forEach(btn => {
        btn.addEventListener('click', e => {
            e.stopPropagation();

            const tr = btn.closest('tr');
            currentRow = tr;
            
            let paymentStatus = null
            const formalityStatus = Number(tr.dataset.formalityStatus);
            if (formalityStatus != 5)
                paymentStatus = Number(tr.dataset.paymentStatus);

            const paymentActions = PAYMENT_ACTIONS[paymentStatus] || [];
            const formalityActions = [];

            // Vide le menu avant de régénérer
            currentMenu.innerHTML = '';

            // Démarrer si paiement accepté ET formalité en attente
            if (paymentStatus === 3 && formalityStatus === 1) {
                formalityActions.push('demarrer_formalite');
            }

            // Terminer si formalité en traitement
            if (formalityStatus === 1 && paymentStatus != 2) {
                formalityActions.push('annuler_formalite');
            }

            // Terminer si formalité en traitement
            if (formalityStatus === 2) {
                formalityActions.push('terminer_formalite', 'rejeter_formalite', 'annuler_formalite', 'reference_inpi', 'envoyer_mail');
            }

            const baseClass = 'w-full text-small text-left hover:bg-gray-100 action-option px-3 py-2';

            // --- ACTIONS PAIEMENT ---
            if (paymentActions.length > 0) {
                paymentActions.forEach(actionKey => {
                    const styleClass = ACTION_STYLES[actionKey] || 'text-gray-700';
                    const button = document.createElement('button');
                    button.className = `${baseClass} ${styleClass}`;
                    button.dataset.action = actionKey;
                    button.dataset.type = 'payment';
                    button.textContent = ACTION_LABELS[actionKey];
                    currentMenu.appendChild(button);
                });
            }

            // Séparateur si nécessaire
            if (paymentActions.length > 0 && formalityActions.length > 0) {
                const separator = document.createElement('div');
                separator.className = 'border-t my-1';
                currentMenu.appendChild(separator);
            }

            // --- ACTIONS FORMALITÉ ---
            if (formalityActions.length > 0 ) {
                formalityActions.forEach(actionKey => {
                    const styleClass = ACTION_STYLES[actionKey] || 'text-gray-700';
                    const button = document.createElement('button');
                    button.className = `${baseClass} ${styleClass}`;
                    button.dataset.action = actionKey;
                    button.dataset.type = 'formality';
                    button.textContent = ACTION_LABELS[actionKey];
                    currentMenu.appendChild(button);
                });
            }

            if (paymentActions.length === 0 && formalityActions.length === 0) {
                return;
            }

            // Positionnement
            const rect = btn.getBoundingClientRect();
            currentMenu.style.top = `${rect.bottom + window.scrollY + 10}px`;
            currentMenu.style.left = `${rect.left + window.scrollX - 160}px`;

            currentMenu.classList.remove('hidden');
        });
    });


    // Click de l'action
    currentMenu.addEventListener('click', async e => {
        if (!currentRow) return;

        const opt = e.target.closest('.action-option');

        if (!opt) return;

        const action = opt.dataset.action;
        const demandeId = currentRow.dataset.id;
        const ref_inpi = currentRow.dataset.ref_inpi;
        const name = currentRow.dataset.name + ' ' + currentRow.dataset.firstname;
        const email = currentRow.dataset.email

        opt.disabled = true;
        opt.classList.add('opacity-50', 'pointer-events-none');

        try {
            // Envoie de la facture + paiement stripe
            if (action === 'envoyer_facture') {

                // Appel à ton endpoint pour générer le paiement Stripe
                const result = await fetch('/api/stripe/create-invoice', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ demandeId: demandeId })
                });

                const data = await result.json();
                if (!result.ok) throw new Error(data.error || 'Erreur paiement');

                // Envoie du mail de demande de PJ
                await fetch('/api/mailjet/request-documents', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({ demandeId: demandeId })
                });

                location.reload();
            }

            // Relance d'un lien de paiement stripe
            if (action === 'relancer_facture') {
                const result = await fetch('/api/stripe/remind-invoice', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ demandeId: demandeId })
                });
                const data = await result.json();
                if (!result.ok) throw new Error(data.error || 'Erreur relance');

                location.reload();
            }

            // Annulation d'un lien de paiement stripe
            // Envoie de mail d'annulation
            if (action === 'annuler_facture') {
                const result = await fetch(`/api/stripe/cancel-invoice`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ demandeId: demandeId })
                });
                const data = await result.json();

                if (!result.ok) throw new Error(data.error || "Erreur lors de l'anulation");

                location.reload();
            }

            // Remboursement d'une partie
            if (action === 'rembourser_facture') {
                let input = prompt("Saisir le montant du remboursement en centimes :");

                // Si l'utilisateur annule ou ne saisit rien
                if (!input) return;

                // Vérifier que c'est un nombre entier positif
                const amount = parseInt(input, 10);
                if (isNaN(amount) || amount <= 0) {
                    alert("Montant invalide. Veuillez saisir un nombre positif en centimes.");
                    return;
                }

                // Confirmation avant envoi
                const confirmMsg = `Remboursement de ${(amount / 100).toFixed(2)} € ${name}, référence INPI ${ref_inpi}. Voulez-vous continuer ?`;
                if (!confirm(confirmMsg)) return;

                try {
                    const result = await fetch('/api/stripe/refund-invoice', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ 
                            demandeId: demandeId,
                            amount: amount
                        })
                    });

                    const data = await result.json();
                    if (!result.ok) throw new Error(data.error || 'Erreur lors du remboursement');

                    // Envoie du mail de notification du remboursement
                    await fetch('/api/mailjet/refund-invoice', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify({
                            demandeId: demandeId,
                            amount: (amount / 100).toFixed(2).toString() 
                        })
                    });

                    location.reload();
                } catch (err) {
                    console.error(err);
                    alert("Erreur :", err.message || "Impossible d'envoyer le remboursement");
                }
            }

            // Actions formalité
            const formaliteActionsList = ['demarrer_formalite', 'terminer_formalite', 'rejeter_formalite', 'annuler_formalite'];

            if (formaliteActionsList.includes(action)) {
                try {
                    if ((action === 'terminer_formalite' || action === 'rejeter_formalite') && !ref_inpi){
                        alert('Veuillez renseigner la référence INPI afin de valider votre action');
                        return;
                    }
                    const result = await fetch(`/api/supabase/update-formality-status`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ demandeId: demandeId, action })
                    });
                    const data = await result.json();

                    if (!result.ok) throw new Error(data.error || "Erreur lors de la mise à jour du statut de la formalité");

                    // Envoi du mail de confirmation
                    try{
                        const result = await fetch('/api/mailjet/formality-notification', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                            },
                            body: JSON.stringify({ demandeId: demandeId, action: action })
                        });
                        if (!result.ok) throw new Error(data.error || "Erreur lors de l'envoi du mail de confirmation");
                    } catch (err) {
                        console.error('Erreur lors de la requête mailjet:', err);
                    }

                    location.reload();

                } catch (err) {
                    console.error(err);
                    alert(`Erreur lors de l'action ${action}`);
                    opt.disabled = false;
                    opt.classList.remove('opacity-50', 'pointer-events-none');
                }
            }

            // Ajouter la référence INPI
            if (action === 'reference_inpi') {

                const refInpi = prompt("Saisir la référence INPI :");

                // Si l'utilisateur annule ou ne saisit rien
                if (!refInpi) return;

                const result = await fetch(`/api/supabase/update-ref-inpi`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        demandeId: demandeId,
                        ref_inpi: refInpi
                    })
                });

                const data = await result.json();

                if (!result.ok) throw new Error(data.error || "Erreur lors de la mise à jour");

                location.reload();
            }

            // Envoi d'un email
            if (action === 'envoyer_mail')
                window.location.href = `mailto:${email}`;

        } catch (err) {
            console.error('catch ', err);
            alert(`Erreur lors de l'action ${action}`);
            opt.disabled = false;
            opt.classList.remove('opacity-50', 'pointer-events-none');
        }

        currentMenu.classList.add('hidden');
    });

    // Click extérieur / fermé
    document.addEventListener('click', () => {
        if (currentMenu) currentMenu.classList.add('hidden');
    });


    /*** Téléchargement du pdf ***/
    document.querySelectorAll('button[data-pdf]').forEach((btn) =>
        btn.addEventListener('click', async () => {
            const fileName = btn.dataset.pdf

            if (!fileName) return

            try {
                const res = await fetch(`/api/get-pdf?file=${encodeURIComponent(fileName)}`)

                if (!res.ok)
                    throw new Error('Impossible de récupérer le PDF')

                const { signedUrl } = await res.json()
                window.open(signedUrl, '_blank')
            } catch (err) {
                console.error(err)
                alert('Impossible de télécharger le PDF pour le moment.')
            }
        })
    );

    /*** Tri avec indicateur visuel ***/
    const table = document.getElementById('formalities-table');
    let currentSortColumn = null;
    let sortAsc = true;

    table.querySelectorAll('th.sortable').forEach((th) => {
        th.addEventListener('click', () => {
            const tbody = table.querySelector('tbody');
            const rows = Array.from(tbody.querySelectorAll('tr'));
            const columnIndex = th.cellIndex;

            // Détecter changement de colonne pour reset le sens
            if (currentSortColumn !== th) {
                sortAsc = true;
                currentSortColumn = th;
            }

            // Tri
            rows.sort((a, b) => {
                const aValue = a.querySelector(`td:nth-child(${columnIndex + 1})`).dataset.sort;
                const bValue = b.querySelector(`td:nth-child(${columnIndex + 1})`).dataset.sort;
                if (!isNaN(aValue) && !isNaN(bValue))
                    return sortAsc ? Number(aValue) - Number(bValue) : Number(bValue) - Number(aValue);
                return sortAsc ? aValue.localeCompare(bValue) : bValue.localeCompare(aValue);
            });

            rows.forEach((r) => tbody.appendChild(r));

            // Mettre à jour l'indicateur
            table.querySelectorAll('th.sortable .sort-indicator').forEach((si) => (si.textContent = '▲▼'));
            th.querySelector('.sort-indicator').textContent = sortAsc ? '▲' : '▼';

            sortAsc = !sortAsc;
        });
    });
    

    /*** Bouton de déconnexion ***/
    const btn = document.getElementById('logout-btn');

    btn.addEventListener('click', async (e) => {
        e.preventDefault();

        // ✅ désactive le bouton pour éviter plusieurs clics
        btn.disabled = true;
        btn.textContent = 'Déconnexion…';

        try {
            const res = await fetch('/api/admin/logout');
            const data = await res.json();

            if (data.success)
            window.location.href = '/admin/maf/login';
            else {
                btn.disabled = false;
                btn.textContent = 'Déconnexion';
            }
        } catch (err) {
            console.error('Erreur logout :', err);
            btn.disabled = false;
            btn.textContent = 'Déconnexion';
        }
    });

    document.addEventListener("DOMContentLoaded", () => {
        const btn = document.getElementById("statusDropdownBtn");
        const menu = document.getElementById("statusDropdownMenu");

        if (!btn || !menu) return;

        // Toggle menu
        btn.addEventListener("click", () => {
            menu.classList.toggle("hidden");
        });

        // Fermer si clic extérieur
        document.addEventListener("click", (e) => {
            if (!btn.contains(e.target) && !menu.contains(e.target)) {
                menu.classList.add("hidden");
            }
        });

        // 👉 ICI on met ton code
        const current = new URLSearchParams(window.location.search).get("statut");

        const labels = {
            1: "En attente",
            2: "En traitement",
            3: "Terminé",
            4: "Rejetée",
            5: "Annulée"
        };

        if (current && labels[current]) {
            btn.textContent = "Filtré par : " + labels[current];
        }
    });
    
</script>