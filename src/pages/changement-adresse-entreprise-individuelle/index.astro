---
import Layout from '@layouts/Layout.astro';
import Hero from '@components/sections/Hero.astro';
import SplitPanel from '@components/sections/SplitPanel.astro';
import Features from '@components/sections/Features.astro';
import Stats from '@components/sections/Stats.astro';
import { featureLists } from '@data/features';
import { statsLists } from '@data/stats';
import CtaBanner from '@components/sections/CtaBanner.astro';
import Faqs from '@components/sections/Faqs.astro';
import { faqLists } from '@data/faqs';
import heroImage from '@assets/images/home/move.jpg';
import styleGuideImage from '@assets/images/home/advisor.jpg';

const image = 'https://www.mon-assistant-formalites.fr/images/home/move.jpg';

const seoTitle = "Changement d’adresse entreprise individuelle (EI) | Modification INPI simplifiée";
const seoDescription = "Modifiez l’adresse de votre entreprise individuelle simplement et sans erreur avec un mandataire INPI. Dossier de modification complet, conforme et accompagné.";

const heroContent = {
    title: 'Modifiez l’adresse de votre entreprise individuelle simplement et sans erreur',
    description: 'Je vous accompagne dans le changement d’adresse de votre activité : préparation du dossier de modification, vérification des informations et dépôt auprès de l’INPI.',
    buttons: [
        { text: 'Modifier mon adresse', link: '/services/changement-adresse-entreprise-individuelle', "data-analytics": "Hero_address_change_cta_click", target: '_self' },
    ],
    backgroundImage: heroImage,
    overlayOpacity: 0.25,
};

const featuresSection = {
    eyebrow: 'Changement d’adresse entreprise individuelle',
    title: 'Une modification simple, rapide et sécurisée',
    description: 'Je vous accompagne dans toutes les étapes du changement d’adresse de votre entreprise individuelle : préparation du dossier, vérification des informations et dépôt auprès de l’INPI.',
    features: featureLists.move.features,
    button: { text: 'Modifier mon adresse', link: '/services/changement-adresse-entreprise-individuelle', "data-analytics": "Features_address_change_cta_click", variant: 'primary' as const },
};

const mainCta = {
    eyebrow: 'Changement d’adresse entreprise individuelle',
    title: 'Modifiez votre adresse simplement et sans erreur',
    description: 'Je vous accompagne dans la mise à jour de l’adresse de votre entreprise individuelle : préparation du dossier, vérification et dépôt auprès de l’INPI. Vous gagnez du temps et évitez les erreurs.',
    button: { text: 'Modifier mon adresse', link: '/services/changement-adresse-entreprise-individuelle', "data-analytics": "Main_cta_address_change_click",variant: 'primary' as const, target: '_self' as const },
};

const styleGuideSection = {
    eyebrow: 'Changement d’adresse entreprise individuelle',
    headline: 'Une modification simple, encadrée et sans erreur',
    description: 'Changer l’adresse de son entreprise individuelle peut entraîner des erreurs administratives. Je vous accompagne pour constituer un dossier conforme et mettre à jour votre situation auprès de l’INPI en toute sérénité.',
    image: { src: styleGuideImage, alt: 'Changement d’adresse entreprise individuelle - mise à jour du dossier INPI' },
    buttons: [
        { text: 'Modifier mon adresse', link: '/services/changement-adresse-entreprise-individuelle', "data-analytics": "styleguide_address_change_cta_click", variant: 'primary' as const },
    ],
};

const linkCta = {
    eyebrow: 'Autres démarches',
    title: 'Une erreur sur votre entreprise ?',
    description: 'Si vos informations sont incorrectes sur le RNE, vous pouvez demander une correction pour remettre votre dossier en conformité.',
    button: { text: 'Corriger le RNE', link: '/correction-rne', "data-analytics": "Link_cta_address_change_click",variant: 'primary' as const, target: '_self' as const },
};

const sideBySideStats = {
    eyebrow: 'Changement d’adresse entreprise individuelle',
    title: 'Une mise à jour simple, rapide et sécurisée',
    description: 'Je vous accompagne dans la modification de votre adresse d’entreprise individuelle pour éviter les erreurs et assurer la conformité de votre dossier.',
    variant: 'side-by-side' as const,
    stats: statsLists.move.stats,
    content: {
        title: 'Une modification conforme dès le premier dépôt',
        description: 'Je vérifie l’ensemble de votre dossier avant dépôt pour limiter les risques d’erreur et garantir la bonne mise à jour de votre entreprise.',
    },
};

const faqsSection = {
    eyebrow: "Changement d’adresse entreprise individuelle",
    title: 'Tout ce que vous devez savoir avant de modifier votre adresse',
    description: 'Je réponds aux questions les plus fréquentes sur le changement d’adresse d’une entreprise individuelle et mon accompagnement.',
    faqs: faqLists.move.faqs,
};

const FooterCta = {
    eyebrow: "Changement d’adresse entreprise individuelle",
    title: 'Modifiez votre adresse en toute simplicité',
    description: 'Je vous accompagne dans la mise à jour de votre entreprise individuelle : préparation du dossier, vérification et dépôt auprès de l’INPI.',
    hideCta: false,
    button: { text: 'Modifier mon adresse', link: '/services/changement-adresse-entreprise-individuelle', "data-analytics": "footer_address_change_cta_click", target: '_self' },
};

---

<Layout footerCta={FooterCta} title={seoTitle} description={seoDescription} theme='athena' image={image}>
    <Hero content={heroContent} />
    <Features content={featuresSection} padding="responsive" background="base" />
    <CtaBanner content={mainCta} variant="contained" background="light" paddingBottom="responsive" />
    <SplitPanel content={styleGuideSection} imagePosition="right" background="base" padding="responsive" />
    <CtaBanner content={linkCta} variant="contained" background="light" paddingBottom="responsive" />
    <Stats content={sideBySideStats} background="dark" padding="responsive" />
    <Faqs content={faqsSection} background="base" padding="responsive" />
</Layout>
