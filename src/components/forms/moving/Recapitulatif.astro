---
import Button from '@components/ui/Button.astro';

const formBackground = 'light';
---


<h3 class="text-xl-2 font-semibold mb-4">Récapitulatif de vos informations</h3>

<form id="recap-form">
    <div id="recap-container" class="space-y-4 text-small mb-4"></div>

    <div class="mb-4">
        <label class="flex items-center space-x-2">
            <input type="checkbox" id="certify" required class="w-4 h-4 text-primary border-gray-300 rounded"/>
            <span class="text-sm text-gray-700">
                Je certifie que les informations fournies sont exactes et que j’ai pris connaissance et accepté les 
                <a href="/legal/conditions-generales-de-vente" target="_blank" class="text-blue-600 underline">Conditions Générales</a> de Mon Assistant Formalités.  
                Je consens à ce que ma demande soit transmise pour traitement.
            </span>                           
        </label>
    </div>

    <div class="flex justify-between my-8">
        <Button href="/forms/moving/adresse" variant="primary" size="md" class="uppercase">Étape précédente</Button>
        <Button type="submit" variant="primary" size="md" class="uppercase" id="submit-formality">Envoyer</Button>
    </div>
</form>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>

<script type="module">
    const { jsPDF } = window.jspdf;

    function generateDemandeId() {
        const brand = 'MAF';
        const prefix = 'MO';

        // Date format YYMMDD
        const now = new Date();
        const year = String(now.getFullYear()).slice(-2);
        const month = String(now.getMonth() + 1).padStart(2, '0');
        const day = String(now.getDate()).padStart(2, '0');
        const datePart = `${year}${month}${day}`;

        // 7 caractères alphanumériques aléatoires
        const array = new Uint8Array(4);
        window.crypto.getRandomValues(array);
        const randomPart = Array.from(array)
            .map((b) => b.toString(16).padStart(2, '0'))
            .join('')
            .slice(0, 7)
            .toUpperCase();

        return `${brand}${prefix}-${datePart}-${randomPart}`;
    }

    async function generateRecapPdf(demandeId, recapContainer, options = { download: true }) {
        const download = options.download;
        const doc = new jsPDF();
        const pageWidth = doc.internal.pageSize.getWidth();
        const pageHeight = doc.internal.pageSize.getHeight();
        let y = 20;

        /* HEADER */
        const img = new Image();
        img.src = '/images/logo.png';
        await new Promise((resolve, reject) => {
            img.onload = resolve;
            img.onerror = reject;
        });

        const logoWidth = 130;
        const ratio = img.height / img.width;
        const logoHeight = logoWidth * ratio;
        doc.addImage(img, 'PNG', pageWidth / 2 - logoWidth / 2, y, logoWidth, logoHeight);
        y += logoHeight + 10;

        doc.setFontSize(12);
        doc.setTextColor(33, 33, 33);
        doc.text('Récapitulatif de demande de modification', pageWidth / 2, y, { align: 'center' });
        y += 10;

        doc.setFontSize(10);
        doc.setFont('helvetica', 'normal');
        const today = new Date().toLocaleDateString('fr-FR');
        doc.text(`N° Dossier : ${demandeId}`, 20, y);
        doc.text(`Date : ${today}`, pageWidth - 20, y, { align: 'right' });
        y += 15;

        /* CONTENT */
        const sections = recapContainer.querySelectorAll('.bg-white');

        for (const section of sections) {
            const titleEl = section.querySelector('h3');
            if (!titleEl) continue;

            const title = titleEl.textContent.trim();

            if (y > pageHeight - 30) {
                doc.addPage();
                y = 20;
            }

            // ===== TITRE SECTION =====
            doc.setFont('helvetica', 'bold');
            doc.setFontSize(14);
            doc.setTextColor(26, 60, 140);
            doc.text(title, 20, y);

            y += 4;

            doc.setDrawColor(26, 60, 140);
            doc.setLineWidth(0.5);
            doc.line(20, y, pageWidth - 20, y);

            y += 8;

            const lines = section.querySelectorAll('div.border-b');

            for (const line of lines) {
                const labelEl = line.querySelector('.font-medium');
                const valueEl = line.querySelector('span.text-gray-600');

                const label = labelEl ? labelEl.innerText.trim() : '';
                const value = valueEl ? valueEl.innerText.trim() : '';

                const fullWidth = pageWidth - 40;
                const lineHeight = 5;

                if (!value && !label) continue;

                // ===== CAS 1 : TITRE DE CORRECTION =====
                if (label && !value) {
                    if (y > pageHeight - 20) {
                        doc.addPage();
                        y = 20;
                    }

                    doc.setFont('helvetica', 'bold');
                    doc.setFontSize(12);
                    doc.setTextColor(0, 0, 0);

                    doc.text(label, 20, y);
                    y += 6;

                    continue;
                }

                // ===== CAS 2 : TEXTE (textarea) =====
                if (!label && value) {
                    const splitValue = doc.splitTextToSize(value, fullWidth);
                    const blockHeight = splitValue.length * lineHeight + 6;

                    if (y + blockHeight > pageHeight - 20) {
                        doc.addPage();
                        y = 20;
                    }

                    // fond léger (effet carte)
                    doc.setFillColor(245, 247, 250);
                    doc.roundedRect(18, y - 3, fullWidth + 4, blockHeight, 2, 2, 'F');

                    doc.setFont('helvetica', 'normal');
                    doc.setFontSize(11);
                    doc.setTextColor(40, 40, 40);

                    doc.text(splitValue, 20, y + 2);

                    y += blockHeight + 4;
                    continue;
                }

                // ===== CAS 3 : LIGNE CLASSIQUE =====
                const labelWidth = 65;
                const valueWidth = pageWidth - 40 - labelWidth;

                const splitLabel = doc.splitTextToSize(label, labelWidth - 5);
                const splitValue = doc.splitTextToSize(value, valueWidth);

                const rowHeight = Math.max(splitLabel.length, splitValue.length) * lineHeight;

                if (y + rowHeight > pageHeight - 20) {
                    doc.addPage();
                    y = 20;
                }

                doc.setFont('helvetica', 'bold');
                doc.setFontSize(11);
                doc.setTextColor(60, 60, 60);
                doc.text(splitLabel, 20, y);

                doc.setFont('helvetica', 'normal');
                doc.setTextColor(33, 33, 33);
                doc.text(splitValue, 20 + labelWidth, y);

                y += rowHeight + 3;
            }

            y += 6;
        }

        /* FOOTER + tampon sur chaque page */
        const totalPages = doc.getNumberOfPages();
        for (let i = 1; i <= totalPages; i++) {
            doc.setPage(i);

            const stampText = `CERTIFIÉ`;
            const stampX = pageWidth / 2;
            const stampY = pageHeight / 2;
            const fontSize = 30;
            const angle = -25;

            doc.setFont('helvetica', 'bold');
            doc.setFontSize(fontSize);
            doc.setTextColor(200, 0, 0);
            doc.setDrawColor(200, 0, 0);
            doc.setLineWidth(1);

            doc.setGState(new doc.GState({ opacity: 0.2 }));
            doc.text(stampText, stampX, stampY, { align: 'center', angle });
            doc.setGState(new doc.GState({ opacity: 1 }));

            doc.setFont('helvetica', 'normal');
            doc.setFontSize(10);
            doc.setTextColor(120);

            doc.text('Document généré automatiquement par Mon Assistant Formalités', pageWidth / 2, pageHeight - 15, {
                align: 'center',
            });
            doc.text(
                `Certifié conforme par le déclarant le ${today} après acceptation des CGV`,
                pageWidth / 2,
                pageHeight - 10,
                { align: 'center' },
            );
            doc.text(`Page ${i} / ${totalPages}`, pageWidth - 20, pageHeight - 10, { align: 'right' });
        }

        if (download) doc.save(`Recap_Correction_${demandeId}.pdf`);
        return doc.output('blob');
    }

    document.addEventListener('DOMContentLoaded', async () => {
        /* CONFIG */

        const STORAGE_KEY_ENTREPRENEUR = 'moving-entrepreneur-form';
        const STORAGE_KEY_ADRESSE = 'moving-adresse-form';

        const recapContainer = document.getElementById('recap-container');
        const form = document.getElementById('recap-form');

        if (!recapContainer || !form) return;

        const countries = await fetch('/data/countries.json').then((r) => r.json());

        const entrepreneur = JSON.parse(localStorage.getItem(STORAGE_KEY_ENTREPRENEUR) || '{}');
        const adresse = JSON.parse(localStorage.getItem(STORAGE_KEY_ADRESSE) || '{}');

        /* HELPERS */

        const formatCountry = (code) => {
            if (!code) return '-';
            const c = countries.find((x) => x.code === code);
            return c ? c.name : code;
        };

        const formatNationality = (code) => {
            if (!code) return '-';
            const c = countries.find((x) => x.code === code);
            return c ? c.nationality || c.name : code;
        };

        const capitalizeWords = (v = '') =>
            v
                .toLowerCase()
                .split(' ')
                .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
                .join(' ');

        const formatDateFR = (dateStr) => {
            if (!dateStr) return '-';
            const [y, m, d] = dateStr.split('-');
            return `${d}/${m}/${y}`;
        };

        const createLine = (label, values, way = 'right') => {
            if (way === 'left') {
                return `
                <div class="border-b border-gray-200 py-1 flex flex-col">
                    ${label ? `<span class="font-medium mb-1">${label}</span>` : ''}
                    <span class="text-gray-600">${Array.isArray(values) ? values.filter(Boolean).join('<br>') : values || ''}</span>
                </div>
                `;
            } else {
                return `
                <div class="flex justify-between border-b border-gray-200 py-1">
                    <span class="font-medium mr-1">${label}</span>
                    <span class="text-gray-600">${Array.isArray(values) ? values.filter(Boolean).join('<br>') : values || ''}</span>
                </div>
                `;
            }
        };

        const createSection = (title, rows) => {
            const section = document.createElement('div');
            section.className = 'bg-white rounded-sm p-4 shadow-xs';

            section.innerHTML = `
            <h3 class="text-lg font-semibold mb-4">${title}</h3>
            <div class="space-y-1">${rows.join('')}</div>
            `;

            return section;
        };
        const address = `${entrepreneur.tracknumber || ''} ${entrepreneur.complementnumber || ''} ${entrepreneur.tracktype || ''} ${entrepreneur.way || ''} ${entrepreneur.additionaladdress || ''}`;

        const addressParts = `${entrepreneur.tracknumber || ''} ${entrepreneur.complementnumber || ''} ${entrepreneur.tracktype || ''} ${entrepreneur.way || ''} ${entrepreneur.additionaladdress || ''} ${entrepreneur.zipcode || ''} ${capitalizeWords(entrepreneur.city) || ''} ${formatCountry(entrepreneur.country) || ''}`;

        /* DISPLAY RECAP */
        const displayRecap = () => {
            recapContainer.innerHTML = '';
            const correspondanceAddress = `${adresse.transfertracknumber || ''} ${adresse.transfertcomplementnumber || ''} ${adresse.transferttracktype || ''} ${adresse.transfertway || ''} ${adresse.transfertadditionaladdress || ''} ${adresse.transfertzipcode || ''} ${adresse.transfertcity || ''} ${formatCountry(adresse.transfertcountry) || ''}`;

            // ---------------- ENTREPRENEUR ----------------
            if (Object.keys(entrepreneur).length) {
                const rows = [
                    createLine('Email', entrepreneur.email),
                    createLine('Téléphone', entrepreneur.phone),
                ];
                if (entrepreneur.modificationpersonnelles === 'oui')
                    rows.push(createLine("", "Vous avez signalé une mise à jour de vos données personnelles", 'left'));

                rows.push(createLine('Genre', capitalizeWords(entrepreneur.gender)));

                if (entrepreneur.name)
                    rows.push(createLine("Nom d'usage", (entrepreneur.name || '').toUpperCase()));

                rows.push(
                    createLine('Nom de naissance', (entrepreneur.birthname || '').toUpperCase()),
                    createLine('Prénom', capitalizeWords(entrepreneur.firstname)),
                    createLine('Adresse', addressParts),
                );

                if (adresse.correspondance === 'oui')
                    rows.push(createLine("Adresse de correspondance", correspondanceAddress));

                rows.push(
                    createLine('Nationalité', formatNationality(entrepreneur.nationality)),
                    createLine('Pays de naissance', formatCountry(entrepreneur.birthcountry)),
                    createLine('Date de naissance', formatDateFR(entrepreneur.birthdate)),
                    createLine('Situation familiale', entrepreneur.situation),
                );

                recapContainer.appendChild(createSection('Informations personnelles', rows));
            }

            if (Object.keys(entrepreneur).length && entrepreneur.modificationconjoint === 'oui') {
                const rows = [
                    createLine("", "Vous avez déclaré une modification des informations de votre conjoint", 'left'),
                    createLine("Ancienne fonction du conjoint", entrepreneur.oldpartnerfonction),
                    createLine("Nouvelle fonction du conjoint", entrepreneur.partnerfonction)
                ];

                if (entrepreneur.partnerfonction != 'Aucun')
                    rows.push(createLine('Genre', capitalizeWords(entrepreneur.partnergender)));

                if (entrepreneur.partnername)
                    rows.push(createLine("Nom d'usage", (entrepreneur.partnername || '').toUpperCase()));

                if (entrepreneur.partnerfonction != 'Aucun'){
                    rows.push(createLine('Nom de naissance', capitalizeWords(entrepreneur.partnerbirthname)));
                    rows.push(createLine('Prénom', capitalizeWords(entrepreneur.partnerfirstname)));
                    rows.push(createLine('Nationalité', formatNationality(entrepreneur.partnernationality)));
                    rows.push(createLine('Pays de naissance', formatCountry(entrepreneur.partnerbirthcountry)));
                    rows.push(createLine('Date de naissance', formatDateFR(entrepreneur.partnerbirthdate)));
                }

                recapContainer.appendChild(createSection('Informations du conjoint', rows));
            }

            // ---------------- DEMENAGEMENT ----------------
            if (Object.keys(adresse).length && adresse.demenagement) {
                const demenagementAddress = `${adresse.tracknumber || ''} ${adresse.complementnumber || ''} ${adresse.tracktype || ''} ${adresse.way || ''} ${adresse.additionaladdress || ''} ${adresse.zipcode || ''} ${capitalizeWords(adresse.city) || ''} ${formatCountry(adresse.country) || ''}`;
                const rows = [
                    createLine("Date d'effet du déménagement", formatDateFR(adresse.demenagementdate)),
                    createLine("Nouvelle adresse", demenagementAddress),
                ];

                if (adresse.adresseActivite === 'oui'){
                    rows.push(createLine('', "Vous déclarez avoir également un établissement à transférer", 'left'));
                    rows.push(createLine("Siret de l'établissement à transférer", entrepreneur.siren + ' ' + adresse.siret));
                }
                if (adresse.demenagementsalarie === 'oui')
                    rows.push(createLine('', "L'entreprise compte des salariés", 'left'));
                else
                    rows.push(createLine('', "L'entreprise ne compte pas de salarié", 'left'));


                recapContainer.appendChild(createSection("Déménagement de l'entrepreneur", rows));
            }

            // ---------------- TRANSFERT ----------------
            if (Object.keys(adresse).length && adresse.transfert) {
                const transfertAdress = `${adresse.transfertracknumber || ''} ${adresse.transfertcomplementnumber || ''} ${adresse.transferttracktype || ''} ${adresse.transfertway || ''} ${adresse.transfertadditionaladdress || ''} ${adresse.transfertzipcode || ''} ${capitalizeWords(adresse.transfertcity) || ''} ${formatCountry(adresse.transfertcountry) || ''}`;
                const rows = [
                    createLine("Date d'effet du transfert", formatDateFR(adresse.transfertdate)),
                    createLine("Siret de l'établissement à transférer", entrepreneur.siren + ' ' + adresse.transfertsiret),
                ];

                if (adresse.destinationsiret)
                    rows.push(createLine("Établissement d'accueil", entrepreneur.siren + ' ' + adresse.destinationsiret))

                if (adresse.destination){
                    rows.push(createLine("Dénomination de la domiciliation", adresse.domiciliationname));
                    rows.push(createLine("Siren domiciliation", adresse.domiciliationsiren));
                }

                rows.push(createLine("Nouvelle adresse", transfertAdress));
                
                if (adresse.siretdestination === 'autre')
                    rows.push(createLine("Que deviendra l'ancien établissement", capitalizeWords(adresse.autredestination)))
                else
                    rows.push(createLine("Que deviendra l'ancien établissement", capitalizeWords(adresse.siretdestination)))

                if (adresse.transfertsalarie === 'oui')
                    rows.push(createLine('', "L'entreprise compte des salariés", 'left'));
                else
                    rows.push(createLine('', "L'entreprise ne compte pas de salarié", 'left'));


                recapContainer.appendChild(createSection("Transfert d'établissement", rows));
            }

            // OBSERVATION
            const rows = [];
            if (adresse.diffusioninsee == 'oui')
                rows.push(createLine('','Vous avez exercé votre droit d’opposition à la diffusion publique des informations relatives à votre entreprise au répertoire Sirene de l’INSEE'));
            else
                rows.push(createLine('',"Vous n'avez pas exercé votre droit d’opposition à la diffusion publique des informations relatives à votre entreprise au répertoire sirene de l’INSEE"));

            if (adresse.prospection == 'oui')
                rows.push(createLine('', 'Vous avez consenti à la mise à disposition de vos données personnelles à des fins de prospection',),);
            else
                rows.push(createLine('', "Vous n'avez pas consenti à la mise à disposition de vos données personnelles à des fins de prospection",),);

            if (adresse.observation != '') {
                rows.push(createLine('Précisions utiles à votre demande', ''));
                rows.push(createLine('', adresse.observation, 'left'));
            }
            recapContainer.appendChild(createSection('Informations complémentaires', rows));
        };

        displayRecap();

        /* SUBMIT → GENERATE PDF */
        form.addEventListener('submit', async (e) => {
            e.preventDefault();

            const submitBtn = form.querySelector('button[type="submit"]');
            submitBtn.disabled = true;
            submitBtn.textContent = 'Génération du PDF...';

            try {
                submitBtn.disabled = true;
                submitBtn.textContent = 'Génération du PDF...';

                const demandeId = generateDemandeId();

                const pdfBlob = await generateRecapPdf(demandeId, recapContainer, { download: false });

                if (!(pdfBlob instanceof Blob) || pdfBlob.size === 0)
                    throw new Error('Le PDF généré est vide ou invalide.');

                // Convertir en base64 pour stockage temporaire
                const reader = new FileReader();

                reader.onloadend = () => {
                    sessionStorage.setItem('generatedPdf', reader.result);
                };

                reader.readAsDataURL(pdfBlob);

                const pdfBase64 = await new Promise((resolve) => {
                    const reader = new FileReader();
                    reader.onloadend = () => {
                        resolve(reader.result.split(',')[1]);
                    };
                    reader.readAsDataURL(pdfBlob);
                });

                console.log(
                    entrepreneur.email,
                    entrepreneur.phone,
                    entrepreneur.birthname,
                    entrepreneur.firstname,
                    address,
                    entrepreneur.city,
                    entrepreneur.zipcode,
                    entrepreneur.siren,
                    pdfBase64,
                );

                const payload = {
                    demandeId: demandeId,
                    typeFormaliteId: 2,
                    email: entrepreneur.email,
                    phone: entrepreneur.phone,
                    name: entrepreneur.birthname,
                    firstname: entrepreneur.firstname,
                    address: address,
                    city: entrepreneur.city,
                    zipcode: entrepreneur.zipcode,
                    siren: entrepreneur.siren,
                    pdf: pdfBase64,
                };

                submitBtn.textContent = 'Envoi en cours...';

                const response = await fetch('/api/create', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(payload),
                });

                const data = await response.json();

                if (!response.ok) {
                    if (response.status === 500) {
                        window.location.href = '/serveur_indisponible';
                        return;
                    }
                    if (response.status === 400) {
                        window.location.href = `/doublon?statut=${data.statut}`;
                        return;
                    }
                    throw new Error(data.error || 'Erreur lors de l’envoi');
                }

                // ✅ Succès total
                submitBtn.textContent = 'Envoyé ✔';
                // localStorage.clear();

                window.location.href = `/confirmation?token=${data.token}`;
            } catch (e) {
                window.location.href = '/serveur_indisponible';
            }
        });
    });
</script>
