---
import Button from '@components/ui/Button.astro';

const formBackground = 'light';
---


<h3 class="text-xl-2 font-semibold mb-4">Récapitulatif de vos informations</h3>

<form id="recap-form">
    <div id="recap-container" class="space-y-4 text-small mb-4"></div>

    <div class="mb-4">
        <label class="flex items-center space-x-2">
            <input type="checkbox" id="certify" required class="w-4 h-4 text-primary border-gray-300 rounded"/>
            <span class="text-sm text-gray-700">
                Je certifie que les informations fournies sont exactes et que j’ai pris connaissance et accepté les 
                <a href="/legal/conditions-generales-de-vente" target="_blank" class="text-blue-600 underline">Conditions Générales</a> de Mon Assistant Formalités.  
                Je consens à ce que ma demande soit transmise pour traitement.
            </span>                           
        </label>
    </div>

    <div class="flex justify-between my-8">
        <Button href="/forms/cessation/details" variant="primary" size="md" class="uppercase">Étape précédente</Button>
        <Button type="submit" variant="primary" size="md" class="uppercase" id="submit-formality">Envoyer</Button>
    </div>
</form>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>

<script type="module">
    const { jsPDF } = window.jspdf;
    
    function generateDemandeId() {
        const brand = 'MAF';
        const prefix = 'CE';

        // Date format YYMMDD
        const now = new Date();
        const year = String(now.getFullYear()).slice(-2);
        const month = String(now.getMonth() + 1).padStart(2, '0');
        const day = String(now.getDate()).padStart(2, '0');
        const datePart = `${year}${month}${day}`;

        // 7 caractères alphanumériques aléatoires
        const array = new Uint8Array(4);
        window.crypto.getRandomValues(array);
        const randomPart = Array.from(array)
            .map(b => b.toString(16).padStart(2, '0'))
            .join('')
            .slice(0, 7)
            .toUpperCase();

        return `${brand}${prefix}-${datePart}-${randomPart}`;
    }

    async function generateRecapPdf(demandeId, recapContainer, options = { download: true }) {
        const download = options.download;

        const doc = new jsPDF();
        const pageWidth = doc.internal.pageSize.getWidth();
        const pageHeight = doc.internal.pageSize.getHeight();
        
        doc.addFileToVFS("BrunoAceSC-Regular.ttf", "");
        doc.addFont("BrunoAceSC-Regular.ttf", "BrunoAceSC", "normal");

        let y = 20;

        /* HEADER */
        const img = new Image();
        img.src = "/images/logo.png";
        await new Promise((resolve, reject) => { img.onload = resolve; img.onerror = reject; });

        const logoWidth = 130;
        const ratio = img.height / img.width;
        const logoHeight = logoWidth * ratio;

        doc.addImage(img, "PNG", pageWidth/2 - logoWidth/2, y, logoWidth, logoHeight);

        y += 14;

        doc.setFontSize(12);
        doc.setTextColor(33, 33, 33);
        doc.text('Récapitulatif de demande de cessation', pageWidth / 2, y, { align: 'center' });

        y += 10;

        doc.setFontSize(10);
        doc.setFont('helvetica', 'normal');

        const today = new Date().toLocaleDateString('fr-FR');

        doc.text(`N° Dossier : ${demandeId}`, 20, y);
        doc.text(`Date : ${today}`, pageWidth - 20, y, { align: 'right' });

        y += 15;

        /* CONTENT */
        const sections = recapContainer.querySelectorAll('h3');

        sections.forEach((sectionTitle) => {
            if (y > pageHeight - 30) {
                doc.addPage();
                y = 20;
            }

            doc.setFont('helvetica', 'bold');
            doc.setFontSize(13);
            doc.setTextColor(26, 60, 140);
            doc.text((sectionTitle.textContent || '').trim(), 20, y);
            y += 4;

            doc.setDrawColor(180);
            doc.line(20, y, pageWidth - 20, y);
            y += 8;

            doc.setFont('helvetica', 'normal');
            doc.setFontSize(11);
            doc.setTextColor(33, 33, 33);

            const sectionDiv = sectionTitle.parentElement;
            if (!sectionDiv) return;

            const rows = sectionDiv.querySelectorAll('.flex');

            if (rows.length > 0) {
                // Sections classiques avec .flex
                rows.forEach((row) => {
                    const spans = row.querySelectorAll('span');
                    if (spans.length < 2) return;

                    const label = spans[0].innerText.trim() || '';
                    const value = spans[1].innerText.trim() || '';

                    const labelWidth = 65;
                    const valueWidth = pageWidth - 40 - labelWidth;
                    const fullWidth = pageWidth - 40;
                    const lineHeight = 4.5;

                    // CAS 1 : label vide → affichage pleine largeur
                    if (!label) {

                        const splitValue = doc.splitTextToSize(value, fullWidth);

                        const rowHeight = splitValue.length * lineHeight;

                        if (y + rowHeight > pageHeight - 20) {
                            doc.addPage();
                            y = 20;
                        }

                        doc.setFont('helvetica', 'normal');
                        doc.text(splitValue, 20, y);

                        y += rowHeight + 3;
                        return;
                    }

                    // CAS 2 : affichage normal en 2 colonnes
                    const splitLabel = doc.splitTextToSize(label, labelWidth - 5);
                    const splitValue = doc.splitTextToSize(value, valueWidth);

                    const rowHeight = Math.max(splitLabel.length, splitValue.length) * lineHeight;

                    if (y + rowHeight > pageHeight - 20) {
                        doc.addPage();
                        y = 20;
                    }

                    doc.setFont('helvetica', 'bold');
                    doc.text(splitLabel, 20, y);

                    doc.setFont('helvetica', 'normal');
                    doc.text(splitValue, 20 + labelWidth, y);

                    y += rowHeight + 2;
                });
            }
            y += 6;
        });

        /* FOOTER + tampon sur chaque page */
        const totalPages = doc.getNumberOfPages();

        for (let i = 1; i <= totalPages; i++) {
            doc.setPage(i);

            const stampText = `CERTIFIÉ`;
            const stampX = pageWidth / 2;
            const stampY = pageHeight / 2; // milieu de la page
            const fontSize = 30;
            const angle = -25; // incliné

            doc.setFont("helvetica", "bold");
            doc.setFontSize(fontSize);
            doc.setTextColor(200, 0, 0);
            doc.setDrawColor(200, 0, 0);
            doc.setLineWidth(1);

            // effet transparent
            doc.setGState(new doc.GState({ opacity: 0.2 }));
            doc.text(stampText, stampX, stampY, { align: "center", angle });
            doc.setGState(new doc.GState({ opacity: 1 })); // retour opacité normale

            // Mention en bas de page
            doc.setFont("helvetica", "normal");
            doc.setFontSize(10);
            doc.setTextColor(120);

            // Footer habituel
            doc.text('Document généré automatiquement par Mon Assistant Formalités', pageWidth / 2, pageHeight - 15, { align: 'center' });
            doc.text(`Certifié conforme par le déclarant le ${today} après acceptation des CGV`, pageWidth / 2, pageHeight - 10, { align: "center" });
            doc.text(`Page ${i} / ${totalPages}`, pageWidth - 20, pageHeight - 10, { align: 'right' });
        }

        return doc.output('blob');
    }

    document.addEventListener('DOMContentLoaded', async () => {
        /* CONFIG */

        const STORAGE_KEY_ENTREPRENEUR = 'cessation-entrepreneur-form';
        const STORAGE_KEY_BUSINESS = 'cessation-business-form';
        const STORAGE_KEY_DETAILS = 'cessation-details-form';

        const recapContainer = document.getElementById('recap-container');
        const form = document.getElementById('recap-form');

        if (!recapContainer || !form) return;

        const countries = await fetch('/data/countries.json').then((r) => r.json());

        const entrepreneur = JSON.parse(localStorage.getItem(STORAGE_KEY_ENTREPRENEUR) || '{}');
        const business = JSON.parse(localStorage.getItem(STORAGE_KEY_BUSINESS) || '{}');
        const details = JSON.parse(localStorage.getItem(STORAGE_KEY_DETAILS) || '{}');

        /* HELPERS */

        const formatCountry = (code) => {
            if (!code) return '-';
            const c = countries.find((x) => x.code === code);
            return c ? c.name : code;
        };

        const formatNationality = (code) => {
            if (!code) return '-';
            const c = countries.find((x) => x.code === code);
            return c ? c.nationality || c.name : code;
        };

        const capitalizeWords = (v = '') =>
            v
                .toLowerCase()
                .split(' ')
                .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
                .join(' ');

        const formatDateFR = (dateStr) => {
            if (!dateStr) return '-';
            const [y, m, d] = dateStr.split('-');
            return `${d}/${m}/${y}`;
        };

        const createLine = (label, values, way = 'right') => {
            if (way === 'left') {
                return `
                <div class="border-b border-gray-200 py-1 flex flex-col">
                    ${label ? `<span class="font-medium mb-1">${label}</span>` : ''}
                    <span class="text-gray-600">${Array.isArray(values) ? values.filter(Boolean).join('<br>') : values || ''}</span>
                </div>
                `;
            } else {
                return `
                <div class="flex justify-between border-b border-gray-200 py-1">
                    <span class="font-medium mr-1">${label}</span>
                    <span class="text-gray-600">${Array.isArray(values) ? values.filter(Boolean).join('<br>') : values || ''}</span>
                </div>
                `;
            }
        };

        const createSection = (title, rows) => {
            const section = document.createElement('div');
            section.className = 'bg-white rounded-sm p-4 shadow-xs';

            section.innerHTML = `
            <h3 class="text-lg font-semibold mb-4">${title}</h3>
            <div class="space-y-1">${rows.join('')}</div>
            `;

            return section;
        };
        const address = `${entrepreneur.tracknumber || ''} ${entrepreneur.complementnumber || ''} ${entrepreneur.tracktype || ''} ${entrepreneur.way || ''} ${entrepreneur.additionaladdress || ''}`;

        const addressParts = `${entrepreneur.tracknumber || ''} ${entrepreneur.complementnumber || ''} ${entrepreneur.tracktype || ''} ${entrepreneur.way || ''} ${entrepreneur.additionaladdress || ''} ${entrepreneur.zipcode || ''} ${entrepreneur.city || ''} ${formatCountry(entrepreneur.country) || ''}`;

        /* DISPLAY RECAP */
        const displayRecap = () => {
            recapContainer.innerHTML = '';

            // ---------------- Démarchage ----------------
            if (Object.keys(entrepreneur).length) {

                const rows = [
                    createLine('Comment avez vous connu Mon Assistant Formalités', entrepreneur.hearabout)
                ];
                recapContainer.appendChild(createSection('', rows));
            }

            // ---------------- ENTREPRENEUR ----------------
            if (Object.keys(entrepreneur).length) {

                const rows = [
                    createLine('Genre', capitalizeWords(entrepreneur.gender)),
                    createLine('Nom de naissance', (entrepreneur.birthname || '').toUpperCase()),
                ];
                if (entrepreneur.name) rows.push(createLine("Nom d'usage", (entrepreneur.name || '').toUpperCase()));

                rows.push(
                    createLine('Prénom', capitalizeWords(entrepreneur.firstname)),
                    createLine('Email', entrepreneur.email),
                    createLine('Téléphone', entrepreneur.phone),
                    createLine('Adresse de correspondance', addressParts),
                    createLine('Nationalité', formatNationality(entrepreneur.nationality)),
                );
                recapContainer.appendChild(createSection('Informations personnelles', rows));
            }

            // ---------------- BUSINESS ----------------
            if (Object.keys(business).length) {

                const rows = [
                    createLine("Siren", business.siren),
                    createLine('Micro-entreprise', business.micro),
                    createLine('EIRL avant le 15 février 2022', business.eirl),
                ];

                if (business.domiciliation === 'non') {
                    rows.push(createLine('Domiciliation', business.domiciliation));
                } else {
                    rows.push(createLine('Organisme de domiciliation', business.domiciliationname));
                    rows.push(createLine('Siren de domiciliation', business.domiciliationsiren));
                }
                recapContainer.appendChild(createSection("Informations de l'entreprise", rows))
            }

            // ---------------- DETAILS ----------------

            // Détails de la cessation
            if (Object.keys(details).length) {
                console.log(details);

                const rows = [ createLine("Entreprise agricole", details.agricole) ];

                if (details.destination)
                    rows.push(createLine('Destination', details.destination))

                rows.push(createLine("Cessation temporaire", details.temporaire));
                rows.push(createLine("Cessation suite au décés de l'entrepreneur", details.deces));

                if (details.cessationdate)
                        rows.push(createLine("Date de cessation", formatDateFR(details.cessationdate)));
                else if (details.temporairedate)
                        rows.push(createLine("Date de cessation temporaire", formatDateFR(details.temporairedate)));
                else if (details.decesdate)
                        rows.push(createLine("Date de décès de l'entrepreneur", formatDateFR(details.decesdate)));

                rows.push(createLine("Présence de salariés dans l'entreprise", details.salarie));
                rows.push(createLine("Demande le Maintien de l'immatriculation au Registre National des Entreprises", details.rne));

                recapContainer.appendChild(createSection("Détails de la cessation", rows))
            }

            // Devenir des établissements
            if (Object.keys(details).length) {
                const rows = [];

                const siretValues = Array.isArray(details['siret[]']) ? details['siret[]'] : [details['siret[]']];
                const destinationValues = Array.isArray(details['siretdestination[]']) ? details['siretdestination[]'] : [details['siretdestination[]']];
                const otherValues = Array.isArray(details['autredestination[]']) ? details['autredestination[]'] : [details['autredestination[]']];

                siretValues.forEach((siret, i) => {
                    let destination = destinationValues[i] || '';
                    if (destination === 'autre' && otherValues[i]) destination += ` : ${otherValues[i]}`;
                    rows.push(createLine(`Établissement ${i + 1} (SIRET ${business.siren} ${siret})`, destination));
                });

                recapContainer.appendChild(createSection("Devenir des établissements", rows));
            }

            // ---------------- Information suppléant ----------------
            if (Object.keys(details).length && details.deces === 'oui') {
                const addressParts = `${details.tracknumber || ''} ${details.complementnumber || ''} ${details.tracktype || ''} ${details.way || ''} ${details.additionaladdress || ''} ${details.zipcode || ''} ${details.city || ''} ${formatCountry(details.country) || ''}`;

                const rows = [
                    createLine('Genre', capitalizeWords(details.gender)),
                    createLine('Nom de naissance', (details.birthname || '').toUpperCase()),
                ];
                if (details.name) rows.push(createLine("Nom d'usage", (details.name || '').toUpperCase()));

                rows.push(
                    createLine('Prénom', capitalizeWords(details.firstname)),
                    createLine('Date de naissance', formatDateFR(details.birthdate)),
                    createLine('Nationalité', formatNationality(details.nationality)),
                    createLine('Pays de naissance', formatCountry(details.birthcountry)),
                    createLine('Ville de naissance', capitalizeWords(details.birthcity)),
                    createLine('Situation maritale', capitalizeWords(details.situation)),
                    createLine('Adresse', addressParts),
                );

                recapContainer.appendChild(createSection("Informations suppléant désigné", rows))
            }
            // OBSERVATION
            const rows = [];
            if (details.diffusioninsee == 'oui')
                rows.push(createLine('','Vous avez exercé votre droit d’opposition à la diffusion publique des informations relatives à votre entreprise au répertoire sirene de l’INSEE'));
            else
                rows.push(createLine('',"Vous n'avez pas exercé votre droit d’opposition à la diffusion publique des informations relatives à votre entreprise au répertoire sirene de l’INSEE"));

            if (details.prospection == 'oui')
                rows.push(createLine('','Vous avez consenti à la mise à disposition de vos données personnelles à des fins de prospection'));
            else
                rows.push(createLine('',"Vous n'avez pas consenti à la mise à disposition de vos données personnelles à des fins de prospection"));

            if (details.observation != '') {
                rows.push(createLine('Précision utile à votre demande', ''));
                rows.push(createLine('', details.observation, 'left'));
            }
            recapContainer.appendChild(createSection('Informations complémentaires', rows));
        };

        displayRecap();

        /* SUBMIT → GENERATE PDF */
        form.addEventListener('submit', async (e) => {
            e.preventDefault();

            const submitBtn = form.querySelector('button[type="submit"]');
            submitBtn.disabled = true;
            submitBtn.textContent = 'Génération du PDF...';

            try {
                submitBtn.disabled = true;
                submitBtn.textContent = 'Génération du PDF...';

                const demandeId = generateDemandeId();

                const pdfBlob = await generateRecapPdf(demandeId, recapContainer, { download: false });

                if (!(pdfBlob instanceof Blob) || pdfBlob.size === 0)
                    throw new Error('Le PDF généré est vide ou invalide.');

                // Convertir en base64 pour stockage temporaire
                const reader = new FileReader();

                reader.onloadend = () => {
                    sessionStorage.setItem('generatedPdf', reader.result);
                };

                reader.readAsDataURL(pdfBlob);

                const pdfBase64 = await new Promise((resolve) => {
                    const reader = new FileReader();
                    reader.onloadend = () => {
                        resolve(reader.result.split(',')[1]);
                    };
                    reader.readAsDataURL(pdfBlob);
                });

                const payload = {
                    demandeId: demandeId,
                    typeFormaliteId: 5,
                    email: entrepreneur.email,
                    phone: entrepreneur.phone,
                    name: entrepreneur.birthname,
                    firstname: entrepreneur.firstname,
                    address: address, 
                    city: entrepreneur.city,
                    zipcode: entrepreneur.zipcode,
                    siren: business.siren,
                    pdf: pdfBase64,
                };

                submitBtn.textContent = 'Envoi en cours...';

                const response = await fetch('/api/create', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify(payload),
                });

                const data = await response.json();

                if (!response.ok) {
                    if (response.status === 500) {
                        window.location.href = '/serveur_indisponible';
                        return;
                    }
                    if (response.status === 400) {
                        window.location.href = `/doublon?statut=${data.statut}`;
                        return;
                    }
                    throw new Error(data.error || 'Erreur lors de l’envoi');
                }

                // ✅ Succès total
                submitBtn.textContent = 'Envoyé ✔';

                // Suppression du localStorage
                localStorage.removeItem(STORAGE_KEY_ENTREPRENEUR);
                localStorage.removeItem(STORAGE_KEY_BUSINESS);
                localStorage.removeItem(STORAGE_KEY_DETAILS);

                window.location.href = `/confirmation?token=${data.token}`;
            } catch (e) {
                window.location.href = '/serveur_indisponible';
            }
        });
    });
</script>
