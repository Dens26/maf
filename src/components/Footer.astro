---
import { legalMenu } from '@data/menu';
import Logo from '@components/Logo.astro';
import Button from '@components/ui/Button.astro';
import { siteConfig } from '@data/config';

interface ButtonProps {
    text: string;
    link: string;
    target?: string;
}

interface Props {
    footerCta?: {
        title: string;
        description: string;
        hideCta: boolean;
        button: ButtonProps;
    };
}

const { footerCta } = Astro.props;

const defaultCta = {
    title: "Besoin d'aide ?",
    description: "Confiez vos formalités d’entreprise individuelle à un mandataire INPI. Création, modification, cessation ou correction RNE : gagnez du temps et évitez les erreurs.",
    hideCta: false,
    button: { text: 'Me contacter', link: '/contact', target: '_self' }
};

const cta = footerCta || defaultCta;
const currentYear = new Date().getFullYear();
---

<footer class={`bg-black text-white pb-8 ${cta.hideCta ? 'pt-16' : ''}`}>
  <div class="site-container mx-auto px-4">

    <!-- CTA -->
    {!cta.hideCta && (
      <div class="text-center border-b border-gray-700 mb-12 py-8">
        <h2 class="text-3xl font-bold mb-4" data-aos="fade-up">{cta.title}</h2>
        <p class="text-white mb-6 max-w-2xl mx-auto" data-aos="fade-up" data-aos-delay="100">
          {cta.description}
        </p>
        <Button 
          href={cta.button.link} 
          variant="ghostLight" 
          size="lg" 
          data-aos="fade-up" 
          data-aos-delay="200" 
          {...(cta.button.target && { target: cta.button.target })}
        >
          {cta.button.text}
        </Button>
      </div>
    )}

    <!-- COLONNES -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 pb-8 border-b border-gray-500">

      <!-- Logo + texte SEO -->
      <div>
        <Logo variant="footer"/>
        <p class="mt-4 text-gray-400 text-sm ">Mandataire INPI spécialisé en formalités d’entreprise individuelle : création, modification, cessation et correction RNE. Accompagnement en ligne partout en France.</p>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-lg font-semibold mb-4">Services</h3>
        <nav>
          <ul class="space-y-2 text-gray-400 text-sm">
            <li><a href="/services/creation-entreprise-individuelle" title="Créer votre entreprise individuelle" class="hover:text-white transition-colors">Création entreprise individuelle</a></li>
            <li><a href="/services/modification-adresse-entreprise-individuelle" title="Changer l'adresse de votre entreprise" class="hover:text-white transition-colors">Changement d’adresse</a></li>
            <li><a href="/services/modification-activite-entreprise-individuelle" title="Modifier l'activité de votre entreprise" class="hover:text-white transition-colors">Modification d’activité</a></li>
            <li><a href="/services/correction-entreprise-individuelle" title="Corriger vos informations sur le RNE" class="hover:text-white transition-colors">Correction RNE</a></li>
            <li><a href="/services/cessation-entreprise-individuelle" title="Cesser votre entreprise individuelle" class="hover:text-white transition-colors">Cessation d’entreprise</a></li>
          </ul>
        </nav>
      </div>

      <!-- Articles -->
      <div>
        <h3 class="text-lg font-semibold mb-4">Articles</h3>
        <nav>
          <ul class="space-y-2 text-gray-400 text-sm">
            <li><a href="/blog/obligations-annuelles-entreprise-individuelle" title="Obligations administratives annuelles d'une EI" class="hover:text-white transition-colors">Obligation entreprise individuelle</a></li>
            <li><a href="/blog/creation-entreprise-individuelle" title="Créer son entreprise individuelle étape par étape" class="hover:text-white transition-colors">Création entreprise individuelle</a></li>
            <li><a href="/blog/modification-adresse-entreprise-individuelle" title="Déclarer un changement d'adresse pour son entreprise" class="hover:text-white transition-colors">Changement d’adresse</a></li>
            <li><a href="/blog/modification-activite-entreprise-individuelle" title="Modifier l'activité ou le nom commercial de son entreprise" class="hover:text-white transition-colors">Modification d’activité</a></li>
            <li><a href="/blog/cessation-entreprise-individuelle" title="Radier son entreprise individuelle" class="hover:text-white transition-colors">Cessation d’entreprise</a></li>
          </ul>
        </nav>
      </div>

    </div>

    <!-- BOTTOM -->
    <div class="mt-8 text-center">
      <div class="text-gray-400 text-sm ">
        © {currentYear} {siteConfig.companyName}. Tous droits réservés.
      </div>
    </div>
    <div class="flex justify-center">
        <nav class="mt-2">
            <ul class="flex flex-wrap sm:flex-nowrap gap-6 justify-center">
            {legalMenu.map((item) => (
                <li>
                <a href={item.link} title={item.name} class="text-sm text-gray-400 hover:text-white transition-colors">
                    {item.name}
                </a>
                </li>
            ))}
            </ul>
        </nav>
    </div>

    <!-- TEXTE SEO LÉGER -->
    <p class="text-xs text-gray-400 mt-6 text-center">
      Service en ligne pour entrepreneurs individuels en France. Mandataire INPI, non affilié à l’INPI.
    </p>

  </div>
</footer>