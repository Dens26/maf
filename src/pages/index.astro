---
import Layout from '@layouts/Layout.astro';
import Hero from '@components/sections/Hero.astro';
import SplitPanel from '@components/sections/SplitPanel.astro';
import Features from '@components/sections/Features.astro';
import Stats from '@components/sections/Stats.astro';
import { featureLists } from '@data/features';
import { statsLists } from '@data/stats';
import { logoLists } from '@data/logos';
import CtaBanner from '@components/sections/CtaBanner.astro';
import Faqs from '@components/sections/Faqs.astro';
import { faqLists } from '@data/faqs';
import RecentPosts from '@components/sections/RecentPosts.astro';
import heroImage from '../assets/images/home/default-hero-2.jpg';
import styleGuideImage from '../assets/images/home/advisor.jpg';

const seoTitle = "Mandataire INPI | Création entreprise individuelle, modification et cessation";
const seoDescription =
    "Mandataire INPI spécialisé en entreprise individuelle : création, modification, changement d’adresse, correction RNE et cessation. Service rapide et sans erreur.";

const heroContent = {
    title: 'Mandataire INPI pour vos formalités d’entreprise individuelle',
    description: 'Création d’entreprise individuelle, changement d’adresse, modification d’activité, correction RNE ou cessation : je prends en charge vos formalités administratives rapidement et en toute conformité.',
    buttons: [
        {text: 'CRÉEZ', link: '/services/creation-entreprise-individuelle', target: '_self', ariaLabel: 'Créer une entreprise individuelle en ligne', title: 'Créer une entreprise individuelle'},
        {text: 'DÉMÉNAGEZ', link: '/services/modification-adresse-entreprise-individuelle', target: '_self', ariaLabel: "Changer l'adresse d'une entreprise individuelle en ligne", title: "Changer l'adresse d'une entreprise individuelle"},
        {text: 'MODIFIEZ', link: '/services/modification-activite-entreprise-individuelle', target: '_self', ariaLabel: "Changer l'activité d'une entreprise individuelle en ligne", title: "Changer l'activité d'une entreprise individuelle"},
        {text: 'CORRIGEZ', link: '/services/correction-entreprise-individuelle', target: '_self', ariaLabel: "Corriger les données erronées d'une entreprise individuelle en ligne", title: "Corriger les données erronées d'une entreprise individuelle"},
        {text: 'CESSEZ', link: '/services/cessation-entreprise-individuelle', target: '_self', ariaLabel: "Cesser une entreprise individuelle en ligne", title: "Cesser une entreprise individuelle"},
        {text: 'SIGNEZ', link: '/services/signature-formalite-inpi', target: '_self', ariaLabel: "Signer une formalité INPI", title: "Signer une formalité INPI"},
    ],
    backgroundImage: heroImage,
    overlayOpacity: 0.2,
};

const featuresSection = {
    eyebrow: 'Formalités entreprise individuelle',
    title: 'Création, modification et cessation d’entreprise individuelle',
    description: 'Mandataire INPI, je vous accompagne dans toutes vos formalités : immatriculation, modification, correction RNE et cessation d’activité. Gagnez du temps et évitez les erreurs administratives.',
    features: featureLists.main.features,
    button: { text: 'Voir tous les services', link: '/services', variant: 'primary' as const },
};

const FooterCta = {
    eyebrow: "Besoin d'aide ?",
    title: 'Confiez vos formalités d’entreprise individuelle à un mandataire INPI',
    description: 'Création, modification ou cessation : je prends en charge vos démarches administratives pour vous faire gagner du temps et sécuriser votre situation.',
    hideCta: false,
    button: { text: 'Me contacter', link: '/contact', target: '_self' },
};

const styleGuideSection = {
    eyebrow: 'Pourquoi me faire confiance ?',
    headline: 'Clarté, réactivité et professionnalisme',
    description: 'En tant que mandataire INPI, je traite vos formalités avec rigueur et conformité. Vous bénéficiez d’un accompagnement humain, clair et rapide pour toutes vos démarches d’entreprise individuelle.',
    image: { src: styleGuideImage, alt: 'Documents administratifs en cours de traitement' },
    buttons: [
        { text: 'Découvrir mon approche', link: '/process', variant: 'primary' as const },
    ],
};

const sideBySideStats = {
    eyebrow: 'Chiffres clés',
    title: 'Formalités INPI traitées rapidement et sans erreur',
    description: 'Des entrepreneurs font appel à mes services pour la gestion de leurs formalités d’entreprise individuelle : création, modification, correction RNE et cessation.',
    variant: 'side-by-side' as const,
    stats: statsLists.withContent.stats,
    content: {
        title: 'Formalités INPI traitées rapidement et sans erreur',
        description: 'Des entrepreneurs font appel à mes services pour la gestion de leurs formalités d’entreprise individuelle : création, modification, correction RNE et cessation.',
        // button: { text: 'Voir les témoignages', link: '/stories', variant: 'primary' as const, },
    },
};

const mainCta = {
    eyebrow: 'Démarches facilitées',
    title: 'Formalités administratives sans tracas',
    description: 'Ne perdez plus de temps dans les méandres administratifs. Confiez vos démarches à un professionnel de confiance.',
    button: { text: 'Commencer maintenant', link: '/services', variant: 'primary' as const, target: '_self' as const },
};

const logosSection = {
    eyebrow: "Ils m'ont fait confiance",
    logos: logoLists.main.logos,
};

const faqsSection = {
    eyebrow: "Questions fréquentes",
    title: 'Vos questions, mes réponses',
    description: 'Voici les réponses aux questions les plus souvent posées sur mes prestations et mon fonctionnement.',
    faqs: faqLists.main.faqs,
};

const recentPostsSection = {
    eyebrow: "Conseils pratiques",
    title: "Mieux comprendre vos obligations",
    description: "Je vous partage des conseils utiles pour mieux appréhender les démarches administratives et rester en conformité avec la réglementation.",
    button: { text: "Lire les articles", link: "/blog", variant: "primary" as const },
};
---

<Layout footerCta={FooterCta} title={seoTitle} description={seoDescription}>
    <Hero content={heroContent} />
    <Features content={featuresSection} padding="responsive" background="light" />
    <RecentPosts content={recentPostsSection} background="base" padding="base" postsToShow={2} category="Formalities" />
    <SplitPanel content={styleGuideSection} imagePosition="right" background="light" padding="responsive" />
    <CtaBanner content={mainCta} variant="contained" background="light" paddingBottom="responsive" />
    <!-- <Logos content={logosSection} background="base" padding="small" /> -->
    <Stats content={sideBySideStats} background="dark" padding="responsive" />
    <Faqs content={faqsSection} background="base" padding="responsive" />
</Layout>
